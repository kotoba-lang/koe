{:paths ["src"]
 ;; Built on langgraph (graph agent loop) which brings langchain
 ;; (ChatModel / tools / Datomic-API store). Both are zero-third-party-dep .cljc.
 ;; All telephony/STT/TTS/booking capabilities are HOST-INJECTED ports — no SDK here.
 :deps {io.github.kotoba-lang/langgraph
        {:git/tag "v0.2.0" :sha "133740f3df2f4aa57e9e98b32f70e2483c025a7e"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; local checkouts for workspace development (orgs/kotoba-lang/*)
  :dev {:override-deps {io.github.kotoba-lang/langgraph
                        {:local/root "../langgraph"}
                        io.github.kotoba-lang/langchain
                        {:local/root "../langchain"}}}
  ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}
  :kotoba {:replace-deps {io.github.kotoba-lang/compiler
                          {:git/url "https://github.com/kotoba-lang/compiler.git"
                           :git/sha "78f43e64125e9c4bbe2bfb3a9520ae4b767dc275"}}
           :main-opts ["-m" "kotoba.compiler.cli"]}}}
