{:paths ["src"]
 ;; Built on langgraph-clj (graph agent loop) which brings langchain-clj
 ;; (ChatModel / tools / Datomic-API store). Both are zero-third-party-dep .cljc.
 ;; All telephony/STT/TTS/booking capabilities are HOST-INJECTED ports — no SDK here.
 :deps {io.github.com-junkawasaki/langgraph-clj
        {:git/tag "v0.2.0" :git/sha "133740f"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; local checkouts for workspace development (orgs/com-junkawasaki/*)
  :dev {:override-deps {io.github.com-junkawasaki/langgraph-clj
                        {:local/root "../langgraph-clj"}
                        io.github.com-junkawasaki/langchain-clj
                        {:local/root "../langchain-clj"}}}}}
